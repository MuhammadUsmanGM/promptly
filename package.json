{
  "name": "promptly",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/rules",
    "packages/cli",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build -w packages/rules && npm run build -w packages/cli && npm run build -w packages/server",
    "dev:server": "npm run dev -w packages/server",
    "dev:cli": "npm run dev -w packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
